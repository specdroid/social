# Server
PORT=3001
WA_ENABLED=true
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-random-secret

# Database
DATABASE_URL=file:./dev.db

# Meta Graph API
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_VERIFY_TOKEN=your-verify-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:5173/billing?success=true
STRIPE_CANCEL_URL=http://localhost:5173/billing?canceled=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Facebook session persistence (optional — encrypts saved login cookies)
# FB_SESSION_KEY=your-32-byte-key
