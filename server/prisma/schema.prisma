generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Tier {
  free
  premium
}

enum Role {
  master
  admin
  user
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String?
  passwordHash         String
  role                 Role               @default(user)
  tier                 Tier               @default(free)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  expiresAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  facebookPages        FacebookPage[]
  facebookAccounts     FacebookAccount[]
  instagramAccounts    InstagramAccount[]
  scheduledPosts       ScheduledPost[]
  automationRules      AutomationRule[]
  whatsappSessions     WhatsAppSession[]
  sessions             Session[]
  facebookPostLogs     FacebookPostLog[]
  omnirouteConfigs     OmnirouteConfig[]
  omnirouteApiKeys      OmnirouteApiKey[]
  telegramSessions     TelegramSession[]
  telegramContacts     TelegramContact[]
  telegramConversations TelegramConversation[]
  savedGroupLists      SavedGroupList[]
  allowedNumbers       AllowedNumber[]
  allowedGroups        AllowedGroup[]
  whatsappContacts        WhatsAppContact[]
  whatsappImportedContacts WhatsAppImportedContact[]
  whatsappContactGroups   WhatsAppContactGroup[]
  googleDrives            GoogleDrive[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FacebookPage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  pageId        String   @unique
  pageName      String?
  accessToken   String
  pageToken     String?
  webhookActive Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FacebookAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fbId        String   @unique
  fbName      String?
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstagramAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  igBusinessId  String   @unique
  accountName   String?
  accessToken   String
  webhookActive Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhatsAppSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phone       String?
  isConnected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId])
}

model AutomationRule {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  platform      String
  triggerType   String
  triggerValue  String
  triggerMode   String   @default("anywhere")
  actionType    String
  actionPayload String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScheduledPost {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  platform     String
  content      String
  mediaUrls    String?
  scheduledAt  DateTime
  publishedAt  DateTime?
  status       String    @default("pending")
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FacebookPostLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  pageId      String?
  content     String
  mediaUrls   String?
  status      String
  error       String?
  ruleId      String?
  createdAt   DateTime @default(now())
}

model SavedGroupList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  groups    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, userId])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  source    String
  message   String
  details   String?
  createdAt DateTime @default(now())
}

model AllowedNumber {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  phone     String
  createdAt DateTime @default(now())

  @@unique([phone, userId])
}

model AllowedGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([name, userId])
}

model RetryQueue {
  id          String   @id @default(cuid())
  source      String
  payload     String
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OmnirouteConfig {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  baseUrl      String   @default("https://omniroutelb.duckdns.org/v1")
  apiKey       String   @default("")
  model        String   @default("auto/coding:free")
  systemPrompt String   @default("")
  updatedAt    DateTime @updatedAt

  @@unique([userId])
}

model OmnirouteApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String   @default("")
  key       String
  createdAt DateTime @default(now())

  @@unique([userId, key])
}

model TelegramSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  session    String   @default("")
  phone      String?
  isLoggedIn Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId])
}

model TelegramContact {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tgId       String
  name       String
  phone      String?
  username   String?
  lastSyncAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tgId, userId])
}

model TelegramConversation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tgId          String
  name          String
  type          String
  unreadCount   Int      @default(0)
  lastMessage   String?
  lastMessageAt DateTime?
  lastSyncAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tgId, userId])
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  waJid       String
  lid         String?
  name        String?
  notify      String?
  verifiedName String?
  phoneNumber String?
  createdAt   DateTime @default(now())

  @@unique([userId, waJid])
}

model WhatsAppImportedContact {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  waJid       String
  name        String?
  phoneNumber String?
  createdAt   DateTime @default(now())

  @@unique([userId, phoneNumber])
}

model WhatsAppContactGroup {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  memberJids String
  createdAt  DateTime @default(now())

  @@unique([userId, name])
}

model GoogleDrive {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String?
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
