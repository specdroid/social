generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Tier {
  free
  premium
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String?
  passwordHash         String
  tier                 Tier               @default(free)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  expiresAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  facebookPages        FacebookPage[]
  facebookAccounts     FacebookAccount[]
  instagramAccounts    InstagramAccount[]
  scheduledPosts       ScheduledPost[]
  automationRules      AutomationRule[]
  whatsappSessions     WhatsAppSession[]
   sessions             Session[]
   facebookPostLogs     FacebookPostLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FacebookPage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  pageId        String   @unique
  pageName      String?
  accessToken   String
  pageToken     String?
  webhookActive Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FacebookAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fbId        String   @unique
  fbName      String?
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstagramAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  igBusinessId  String   @unique
  accountName   String?
  accessToken   String
  webhookActive Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhatsAppSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phone       String?
  isConnected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationRule {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  platform      String
  triggerType   String
  triggerValue  String
  actionType    String
  actionPayload String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScheduledPost {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  platform     String
  content      String
  mediaUrls    String?
  scheduledAt  DateTime
  publishedAt  DateTime?
  status       String    @default("pending")
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FacebookPostLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  pageId      String?
  content     String
  mediaUrls   String?
  status      String
  error       String?
  ruleId      String?
  createdAt   DateTime @default(now())
}

model SavedGroupList {
  id        String   @id @default(cuid())
  name      String   @unique
  groups    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  source    String
  message   String
  details   String?
  createdAt DateTime @default(now())
}

model AllowedNumber {
  id        String   @id @default(cuid())
  phone     String   @unique
  createdAt DateTime @default(now())
}

model AllowedGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model RetryQueue {
  id          String   @id @default(cuid())
  source      String
  payload     String
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OmnirouteConfig {
  id           Int      @id @default(autoincrement())
  baseUrl      String   @default("https://omniroutelb.duckdns.org/v1")
  apiKey       String   @default("")
  model        String   @default("auto/coding:free")
  systemPrompt String   @default("")
  updatedAt    DateTime @updatedAt
}

model TelegramSession {
  id         String   @id @default(cuid())
  session    String   @default("")
  phone      String?
  isLoggedIn Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TelegramContact {
  id         String   @id @default(cuid())
  tgId       String   @unique
  name       String
  phone      String?
  username   String?
  lastSyncAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TelegramConversation {
  id            String   @id @default(cuid())
  tgId          String   @unique
  name          String
  type          String
  unreadCount   Int      @default(0)
  lastMessage   String?
  lastMessageAt DateTime?
  lastSyncAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
